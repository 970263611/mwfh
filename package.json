{
  "name": "mwfh",
  "version": "1.0.0",
  "description": "A lightweight text & file transfer interaction tool developed by Dahua",
  "homepage": "https://github.com/970263611/mwfh#readme",
  "bugs": {
    "url": "https://github.com/970263611/mwfh/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/970263611/mwfh.git"
  },
  "license": "MIT",
  "author": "dahua",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:win": "npx electron-builder --win",
    "build:mac": "npx electron-builder --mac",
    "build:linux": "npx electron-builder --linux",
    "build:uos": "npx electron-builder --linux deb"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@roamhq/wrtc": "^0.10.0",
    "electron-squirrel-startup": "^1.0.1",
    "lowdb": "^7.0.1"
  },
  "build": {
    "appId": "world.dahua.mwfh",
    "productName": "mwfh",
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "./logo.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "./logo.png"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        "rpm",
        "zip"
      ],
      "icon": "./logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "./logo.png",
      "uninstallerIcon": "./logo.png",
      "shortcutName": "mwfh"
    }
  }
}

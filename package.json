{
  "name": "mwfh",
  "version": "1.0.0",
  "description": "A lightweight text & file transfer interaction tool developed by Dahua",
  "homepage": "https://github.com/970263611/mwfh#readme",
  "bugs": {
    "url": "https://github.com/970263611/mwfh/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/970263611/mwfh.git"
  },
  "license": "MIT",
  "author": "dahua",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "dev-uos": "npx electron . --no-sandbox --disable-gpu --disable-gpu-sandbox --ozone-platform=x11",
    "build:win": "npx electron-builder --win",
    "build:mac": "npx electron-builder --mac",
    "build:linux": "npx electron-builder --linux",
    "build:uos": "npx electron-builder --linux deb",
    "rebuild:modules": "electron-rebuild -f",
    "rebuild:native": "cd native && ../node_modules/.bin/node-gyp rebuild",
    "rebuild": "npm run rebuild:modules && npm run rebuild:native"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-rebuild": "^3.2.9",
    "node-gyp": "^13.0.1"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "electron-squirrel-startup": "^1.0.1",
    "lowdb": "^7.0.1",
    "node-addon-api": "^8.9.0"
  },
  "build": {
    "appId": "world.dahua.mwfh",
    "productName": "mwfh",
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "./icons/icon-256.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "./icons/icon-512.png",
      "hardenedRuntime": false
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        "rpm",
        "zip"
      ],
      "icon": "./icons/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "./icons/icon-256.ico",
      "uninstallerIcon": "./icons/icon-256.ico",
      "shortcutName": "mwfh"
    }
  }
}

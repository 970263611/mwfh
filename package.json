{
  "name": "mwfh",
  "version": "1.0.0",
  "description": "A lightweight text & file transfer interaction tool developed by Dahua",
  "homepage": "https://github.com/970263611/mwfh#readme",
  "bugs": {
    "url": "https://github.com/970263611/mwfh/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/970263611/mwfh.git"
  },
  "license": "MIT",
  "author": "dahua",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "lowdb": "^7.0.1"
  },
  "build": {
    "productName": "mwfh",
    "appId": "world.dahua.mwfh",
    "win": {
      "target": ["nsis", "zip"],
      "icon": "./logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "./logo.ico",
      "uninstallerIcon": "./logo.ico",
      "shortcutName": "mwfh"
    }
  }
}
